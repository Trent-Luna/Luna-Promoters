# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server only, NEVER expose to the browser.
# Used for admin CSV exports and privileged reads.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used in promoter links & QR codes)
NEXT_PUBLIC_SITE_URL=https://promoter.lunagroup.com.au

# Public memberships URL (used in University pass links & QR codes).
# Optional — falls back to NEXT_PUBLIC_SITE_URL if unset.
NEXT_PUBLIC_MEMBERSHIPS_URL=https://memberships.lunagroup.com.au

# Transactional email (Resend). Server only.
RESEND_API_KEY=your-resend-api-key

# AI university-ID verification (OpenAI GPT-4o). Server only — NEVER expose to the browser.
OPENAI_API_KEY=your-openai-api-key
# Optional model override (defaults to gpt-4o)
OPENAI_VERIFICATION_MODEL=gpt-4o
