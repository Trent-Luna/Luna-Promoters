# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server only, NEVER expose to the browser.
# Used for admin CSV exports and privileged reads.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used in promoter links & QR codes)
NEXT_PUBLIC_SITE_URL=https://promoter.lunagroup.com.au
